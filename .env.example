# Copy to `.env.local` and fill in real values. Never commit secrets.
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Supabase (Next.js client + server)
# Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace-me"

# Server-only: never expose to the browser or NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace-me"

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# RESEND_API_KEY="re_xxxxxxxx"

