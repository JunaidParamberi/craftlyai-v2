# Copy to `.env` (or `.env.local`) for local development. Never commit real secrets.
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Supabase — Dashboard → Project Settings → API
# Prefer publishable key (sb_publishable_...); anon JWT still works as fallback.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_REPLACE_ME"

# Legacy anon key (optional if you use publishable key above)
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace-me"

# Server-only — never expose or prefix with NEXT_PUBLIC_
# SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace-me"

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# RESEND_API_KEY="re_xxxxxxxx"

# -----------------------------------------------------------------------------
# Payments — Lemon Squeezy (CraftlyAI user subscriptions)
# -----------------------------------------------------------------------------
# LEMON_SQUEEZY_API_KEY=""
# LEMON_SQUEEZY_STORE_ID=""
# LEMON_SQUEEZY_SIGNING_SECRET=""

# -----------------------------------------------------------------------------
# Payments — Stripe (client → freelancer in portal)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# -----------------------------------------------------------------------------
# Product analytics / errors (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
# SENTRY_AUTH_TOKEN=""
# NEXT_PUBLIC_SENTRY_DSN=""

# -----------------------------------------------------------------------------
# AI — Edge Functions only in production (see CLAUDE.md)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=""
